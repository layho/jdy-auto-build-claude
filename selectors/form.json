      "数字":     ["li[title='数字']", "li.form-edit-widget-label:has-text('数字')"],
      "日期时间":  ["li[title='日期时间']", "li.form-edit-widget-label:has-text('日期时间')"],
      "单选按钮组": ["li[title='单选按钮组']", "li.form-edit-widget-label:has-text('单选按钮组')"],
      "复选框组":  ["li[title='复选框组']", "li.form-edit-widget-label:has-text('复选框组')"],
      "下拉复选框": ["li[title='下拉复选框']", "li.form-edit-widget-label:has-text('下拉复选框')"],
      "下拉框":   ["li[title='下拉框']", "li.form-edit-widget-label:has-text('下拉框')"],
      "成员多选":  ["li[title='成员多选']", "li.form-edit-widget-label:has-text('成员多选')"],
      "成员单选":  ["li[title='成员单选']", "li.form-edit-widget-label:has-text('成员单选')"],
      "部门多选":  ["li[title='部门多选']", "li.form-edit-widget-label:has-text('部门多选')"],
      "部门单选":  ["li[title='部门单选']", "li.form-edit-widget-label:has-text('部门单选')"],
      "分割线":   ["li[title='分割线']", "li.form-edit-widget-label:has-text('分割线')"],
      "图片":     ["li[title='图片']", "li.form-edit-widget-label:has-text('图片')"],
      "附件":     ["li[title='附件']", "li.form-edit-widget-label:has-text('附件')"],
      "地址":     ["li[title='地址']", "li.form-edit-widget-label:has-text('地址')"],
      "定位":     ["li[title='定位']", "li.form-edit-widget-label:has-text('定位')"],
      "子表单":   ["li[title='子表单']", "li.form-edit-widget-label:has-text('子表单')"],
      "选择数据":  ["li[title='选择数据']", "li.form-edit-widget-label:has-text('选择数据')"],
      "关联数据":  ["li[title='关联数据']", "li.form-edit-widget-label:has-text('关联数据')"],
      "计算":     ["li[title='计算']", "li.form-edit-widget-label:has-text('计算')"],
      "流水号":   ["li[title='流水号']", "li.form-edit-widget-label:has-text('流水号')"],
      "手机":     ["li[title='手机']", "li.form-edit-widget-label:has-text('手机')"],
      "手写签名":  ["li[title='手写签名']", "li.form-edit-widget-label:has-text('手写签名')"],
      "富文本":   ["li[title='富文本']", "li.form-edit-widget-label:has-text('富文本')"],
      "查询":     ["li[title='查询']", "li.form-edit-widget-label:has-text('查询')"]
    },
    "field_name_input": [
      ".fx-field-title-input input.input-inner",
      ".fx-field-title-input input",
      "input[placeholder*='字段名称']",
      "input[placeholder*='标题']",
      "[data-testid='field-name-input']"
    ],
    "field_panel": [
      ".field-add-pane",
      ".field-select-pane",
      "[data-testid='field-config-panel']"
    ],
    "field_properties_panel": [
      "[class*='field-property']",
      "[class*='property-panel']"
    ],
    "widget_category": [
      "[class*='widget-cate']",
      ".form-widget-group-label"
    ]
  },
  "subform": {
    "subform_canvas": [
      ".subform-widget",
      "[class*='sub-form']",
      "[data-widget-type='subform']"
    ]
  },
  "options": {
    "batch_edit_btn": [
      "button:has-text('批量编辑')",
      "[class*='batch-edit']"
    ],
    "options_textarea": [
      "textarea[placeholder*='每行一个']",
      ".options-batch-editor textarea",
      "textarea"
    ],
    "confirm_btn": [
      "button:has-text('确定')"
    ]
  },
  "modal": {
    "close_btn": [
      "[aria-label='关闭']",
      "[data-testid='modal-close']",
      "button:has-text('关闭')",
      "button:has-text('取消')"
    ],
    "confirm_btn": [
      "[data-testid='modal-confirm']",
      "[aria-label='确定']",
      "button:has-text('确定')"
    ],
    "confirm_dialog": [
      ".fx-nav-message",
      ".message",
      "[class*='confirm-dialog']",
      "[role='alertdialog']"
    ]
  },
  "common": {
    "loading_spinner": [
      "[data-testid='loading']",
      "[aria-label='加载中']",
      "[role='progressbar']"
    ],
    "toast_success": [
      ".toast-success",
      "[class*='message-success']"
    ],
    "toast_error": [
      ".toast-error",
      "[class*='message-error']",
      "[role='alert']"
    ],
    "save_btn": [
      "button:has-text('保存')",
      "button.save-btn",
      "[data-testid='save-btn']"
    ]
  }
}
